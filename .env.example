# ─── Backend Configuration ───
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# URL of the frontend for CORS. In production, set to your deployed frontend URL.
FRONTEND_URL=http://localhost:3000

# ─── AI Provider Configuration ───

# Groq API Key (get one at https://console.groq.com)
# Supports multiple comma-separated keys for automatic rotation on rate limits.
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (get one at https://aistudio.google.com)
# Used as fallback when Groq hits rate limits.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── AI Tuning (Optional) ───
# Maximum retry attempts per batch before failing
# AI_MAX_RETRIES=3

# Base delay between retries in milliseconds (uses exponential backoff)
# AI_RETRY_DELAY_MS=2000
